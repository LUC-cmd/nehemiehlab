# Copier vers backend/.env (gitignoré) ou configurer la plateforme d'hébergement.
SPRING_PROFILES_ACTIVE=local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nehemiahlab
DB_USER=postgres
DB_PASSWORD=change-me
JWT_SECRET=generate-at-least-64-random-characters-and-never-commit-it
CORS_ORIGINS=http://localhost:5173

# --- Envoi e-mails (OTP, alertes) — compte Gmail technique dédié à l'envoi ---
# Ex. hiwendjanounai78@gmail.com envoie ; les utilisateurs reçoivent sur LEUR propre email.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-compte-envoi@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM=votre-compte-envoi@gmail.com
MAIL_OTP_FROM=votre-compte-envoi@gmail.com

# Production: stockage S3/R2 privé.
STORAGE_ENDPOINT=https://account-id.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=nehemiahlab-private
STORAGE_ACCESS_KEY=change-me
STORAGE_SECRET_KEY=change-me

# Local : resynchronise les mots de passe à chaque démarrage (voir application-local.properties).
APP_SEED_ENABLED=false
APP_SEED_SYNC_PASSWORDS=true
APP_SEED_DIRECTOR_EMAIL=director@nehemiahlab.com
APP_SEED_DIRECTOR_PASSWORD=password123
APP_SEED_DEMO_PASSWORD=password123
