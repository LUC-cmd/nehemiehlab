# Variables Railway — déploiement TERRAIN (profil field)
# Copiez dans Railway → service API → Variables.

SPRING_PROFILES_ACTIVE=field

# PostgreSQL — Add Reference → Postgres → DATABASE_URL (obligatoire)
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Sécurité — OBLIGATOIRES (générez des vraies valeurs, pas de démo)
JWT_SECRET=(64+ caractères aléatoires — ex. openssl rand -hex 32)
CORS_ORIGINS=https://votre-frontend.up.railway.app

# E-mails — OBLIGATOIRES (inscriptions, OTP, validations)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=hiwendjanounai78@gmail.com
MAIL_PASSWORD=(mot de passe application Gmail)
MAIL_FROM=hiwendjanounai78@gmail.com
MAIL_OTP_FROM=hiwendjanounai78@gmail.com

# Pas de comptes démo par défaut
APP_SEED_ENABLED=false

# Premier déploiement uniquement : créer le directeur initial, puis repasser à false
# APP_SEED_ENABLED=true
# APP_SEED_DIRECTOR_EMAIL=director@votre-domaine.com
# APP_SEED_DIRECTOR_PASSWORD=(mot de passe fort)

# Stockage fichiers (disque Railway — prévoir un volume pour la prod longue)
STORAGE_LOCAL_ROOT=/tmp/nehemiahlab-uploads

# --- Service frontend (Root Directory = frontend) ---
# VITE_API_URL=https://VOTRE-API.up.railway.app/api
