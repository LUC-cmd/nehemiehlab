# Variables Railway — service API (Dockerfile racine)
# Copiez ces clés dans Railway → service API → Variables.
# Seule DATABASE_URL (référence PostgreSQL) est obligatoire côté base.

SPRING_PROFILES_ACTIVE=demo

# Référence Railway : Postgres → DATABASE_URL (ou PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD)
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Optionnel sur Railway : auto-configuré si absent (voir RailwayEnvironmentDefaults)
# JWT_SECRET=(64+ caractères — générez une chaîne aléatoire pour la prod)
# CORS_ORIGINS=https://votre-frontend.up.railway.app

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=hiwendjanounai78@gmail.com
MAIL_PASSWORD=(mot de passe application Gmail)
MAIL_FROM=hiwendjanounai78@gmail.com
MAIL_OTP_FROM=hiwendjanounai78@gmail.com

APP_SEED_ENABLED=true
APP_SEED_DIRECTOR_PASSWORD=password123
APP_SEED_DEMO_PASSWORD=password123

# --- Service frontend (Root Directory = frontend) ---
# VITE_API_URL=https://VOTRE-API.up.railway.app/api
